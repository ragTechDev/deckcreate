# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Media content
/public/sync/audio/*
/public/sync/output/*
/public/sync/video/*
/public/transcribe/input/*
/public/input/*
/public/sync/*
/public/transcribe/*

# Whisper.cpp binary and models (downloaded on first run)
/whisper.cpp/
.claude/settings.local.json

# Python Environments
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Python Byte-compiled / optimized / DLL files
scripts/diarize/__pycache__/
*.py[codz]
*$py.class
