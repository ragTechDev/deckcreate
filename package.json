{
  "name": "deckcreate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "__:development__:": "echo '=== Development ==='",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "__:testing__:": "echo '=== Testing ==='",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "__:main_wizard__:": "echo '=== Main Production Wizard (run this first) ==='",
    "wizard": "node scripts/wizard.js",
    "wizard:docker": "docker compose run --rm --service-ports wizard",
    "__:step_1_sync__:": "echo '=== Step 1: Audio/Video Sync ==='",
    "sync": "node scripts/sync/sync-audio-video.js",
    "__:step_2_transcribe__:": "echo '=== Step 2: Transcription ==='",
    "transcribe": "node scripts/transcribe/transcribe-audio.js",
    "diarize": "node scripts/diarize/diarize-audio.js",
    "assign-speakers": "node scripts/diarize/assign-speakers.js",
    "__:step_3_transcript_edit__:": "echo '=== Step 3: Transcript Editing ==='",
    "edit-transcript": "node scripts/edit-transcript.js",
    "merge-doc": "node scripts/edit-transcript.js --merge-doc public/edit/transcript.doc.txt",
    "merge-doc:cut-pauses": "node scripts/edit-transcript.js --merge-doc public/edit/transcript.doc.txt --auto-cut-pauses 0.5",
    "align": "node scripts/align/align-transcript.js",
    "__:step_4_camera__:": "echo '=== Step 4: Camera Setup ==='",
    "setup-camera": "node scripts/camera/setup-camera.js",
    "setup-camera:docker": "docker compose run --rm --service-ports setup-camera",
    "color-match": "tsx scripts/camera/color-match.ts",
    "color-match:docker": "docker compose run --rm color-match",
    "__:step_5_video_cut_preview__:": "echo '=== Step 5: Video Cut Preview ==='",
    "cut-preview": "node scripts/cut-preview.js",
    "__:step_6_thumbnail__:": "echo '=== Step 6: Thumbnail Creation ==='",
    "thumbnail:wizard": "node scripts/thumbnail/thumbnail-wizard.js",
    "thumbnail:wizard:docker": "docker compose run --rm --service-ports thumbnail node scripts/thumbnail/thumbnail-wizard.js",
    "thumbnail:selectable": "npm run extract-candidates && npm run select-frames && npm run generate-cutouts && npm run thumbnail",
    "thumbnail:simple": "node scripts/thumbnail/generate-thumbnail.js",
    "thumbnail:simple:docker": "docker compose run --rm thumbnail node scripts/thumbnail/generate-thumbnail.js",
    "thumbnail:portrait": "node scripts/thumbnail/generate-portrait-thumbnail.js",
    "extract-candidates": "python3 scripts/thumbnail/extract-speaker-candidates.py --transcript public/edit/transcript.json --camera-profiles public/camera/camera-profiles.json --video public/sync/output/synced-output-1.mp4 --output-dir public/thumbnail/candidates --num-candidates 6",
    "extract-candidates:docker": "docker compose run --rm thumbnail python3 scripts/thumbnail/extract-speaker-candidates.py --transcript public/edit/transcript.json --camera-profiles public/camera/camera-profiles.json --video public/sync/output/synced-output-1.mp4 --output-dir public/thumbnail/candidates --num-candidates 6",
    "select-frames": "node scripts/thumbnail/select-speaker-frames.js",
    "select-frames:docker": "docker compose run --rm -it thumbnail npm run select-frames",
    "generate-cutouts": "node scripts/thumbnail/generate-cutouts-from-selection.js",
    "generate-cutouts:docker": "docker compose run --rm thumbnail npm run generate-cutouts",
    "__:step_7_remotion__:": "echo '=== Step 7: Remotion Video Editing ==='",
    "remotion": "npx remotion studio",
    "remotion:gallery": "npx remotion studio remotion/galleryRoot.ts",
    "render-hook-intro": "node scripts/render-hook-intro.js",
    "__:quality_check__:": "echo '=== Quality Check Tools ==='",
    "hook-qa": "node scripts/hook-qa.js",
    "hook-qa:docker": "docker compose run --rm hook-qa",
    "guest-review": "node scripts/guest-review.js",
    "__:social_carousel__:": "echo '=== Social Media Carousel ==='",
    "generate": "node scripts/carousel/generate-carousel.js",
    "generate:bulk": "node scripts/carousel/generate-carousel.js --bulk",
    "generate:transcript": "node scripts/carousel/CaptionExtractor.js",
    "__:utilities__:": "echo '=== Utilities ==='",
    "vtt-to-srt": "node scripts/shared/vtt-to-srt.js"
  },
  "dependencies": {
    "@mantine/carousel": "^8.3.15",
    "@mantine/core": "^8.3.15",
    "@mantine/dates": "^8.3.15",
    "@mantine/form": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/notifications": "^8.3.15",
    "@remotion/cli": "^4.0.451",
    "@remotion/gif": "^4.0.451",
    "@remotion/install-whisper-cpp": "^4.0.451",
    "@remotion/media-parser": "^4.0.451",
    "@remotion/media-utils": "^4.0.451",
    "@remotion/sfx": "^4.0.451",
    "@tabler/icons-react": "^3.29.0",
    "@types/file-saver": "^2.0.7",
    "dayjs": "^1.11.19",
    "dotenv": "^16.0.0",
    "embla-carousel-react": "^8.6.0",
    "fft.js": "^4.0.4",
    "file-saver": "^2.0.5",
    "canvas": "^3.2.3",
    "fs-extra": "^11.2.0",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "pdfkit": "^0.14.0",
    "puppeteer": "^23.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "^4.0.451",
    "sharp": "^0.33.0",
    "wavefile": "^11.0.0",
    "youtube-transcript": "^1.3.0"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.0.4",
    "@img/sharp-linux-x64": "0.33.5",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.18",
    "lightningcss-linux-x64-gnu": "1.30.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@remotion/eslint-plugin": "^4.0.451",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-jest": "^30.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
